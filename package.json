{
  "name": "scriptboard-app",
  "private": true,
  "version": "0.1.0",
  "description": "ScriptBoard - storyboard and screenplay desktop app",
  "author": "ScriptBoard",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "npm run build && electron-builder",
    "release:demo": "npm run build && electron-builder --win --publish never && node scripts/prepare-distribute.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-color": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-text-style": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "@types/d3-contour": "^3.0.6",
    "adm-zip": "^0.5.16",
    "clsx": "^2.1.1",
    "d3-contour": "^4.0.2",
    "ffmpeg-static": "^5.3.0",
    "flexlayout-react": "^0.8.19",
    "konva": "^10.2.3",
    "lucide-react": "^1.6.0",
    "perfect-freehand": "^1.2.3",
    "pixi.js": "^7.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0",
    "wavesurfer.js": "^7.12.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "asar": "^3.2.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "javascript-obfuscator": "^5.4.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  },
  "build": {
    "appId": "com.scriptboard.app",
    "productName": "ScriptBoard",
    "copyright": "Copyright © ScriptBoard",
    "directories": {
      "output": "Distribution",
      "buildResources": "build-resources"
    },
    "compression": "maximum",
    "files": [
      "package.json",
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "installerLanguages": [
        "en_US"
      ],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.{node,dll}",
      "node_modules/ffmpeg-static/**"
    ]
  }
}
